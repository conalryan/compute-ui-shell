# Akamai CDN root that fronts object storage. Apps are published at:
#   {VITE_APPS_BASE_URL}/compute-ui-<product>/{VITE_APPS_VERSION}/deploy.json
#   → points at a content-hashed entry module (e.g. entry-abc123.js)
#
# Keep VITE_APPS_VERSION=latest so the shell does not need a rebuild when
# individual apps deploy. Pin a version folder only for freezes/rollbacks.
#
# Local examples (after `pnpm build:apps`):
#   VITE_APPS_BASE_URL=http://localhost:5173/apps
VITE_APPS_BASE_URL=https://<akamai-hostname>/apps
VITE_APPS_VERSION=latest
